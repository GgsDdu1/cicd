name: CI

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  test_A800:
    runs-on: ubuntu-latest
    environment: huoshan-env
    env:
      TASK_CONFIG_FILE: ".github/commons/huoshan-mltask.yaml"
      TASKID_FILE: "huoshan_taskid.txt"
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          lfs: true  # 启用 Git LFS 下载
      # 初始化火山引擎 CLI以及更新任务配置
      - name: Initialize volc CLI
        uses: ./.github/actions/init-huoshan
        with:
          access_key: ${{ secrets.VOLC_ACCESS_KEY }}
          secret_key: ${{ secrets.VOLC_SECRET_KEY }}
          region: ${{ secrets.REGION }}
      # 更新任务配置
      - name: Update huoshan config.yaml
        shell: bash
        run: |
          set -e
          echo "🔧 Configuring huoshan config.yaml..."
          python .github/commons/scripts/update_huoshan_yaml.py \
          --yaml-file .github/commons/template/huoshan-mltask-template.yaml \
          --cmd-file .github/commons/scripts/huoshan_cmd.sh \
          --http-proxy "${{ secrets.HTTPS_PROXY }}" \
          --https-proxy "${{ secrets.HTTP_PROXY }}" \
          --commit-id "${GITHUB_SHA}" \
          --output-file "${TASK_CONFIG_FILE}"
      - name: Run huoshan task with Python
        env:
          TASK_NAME: kairos-ci-${{ github.sha }}
          PENDDING_TIME_OUT: 1800
          INTERVAL: 30
        run: |
          python .github/commons/scripts/run_huoshan_task.py
      - name: Cleanup on cancellation
        if: ${{ cancelled() }}
        run: |
          if [ -f {$TASKID_FILE} ]; then
            TASK_ID=$(cat $TASKID_FILE)
            echo "🧹 Cancelling task $TASK_ID due to workflow cancellation"
            volc ml_task cancel --id "$TASK_ID"
          else
            echo "⚠️ No $TASKID_FILE found, skipping cancellation"
          fi
